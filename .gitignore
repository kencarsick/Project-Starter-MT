# Project-specific files (generated by /create-prd and /init-project — keep local only)
PRD.md
PRD-v*.md
CLAUDE.md
AGENTS.md

# Environment
.env
.env.local
.env.*.local

# Worktrees (per-issue isolated workspaces)
.worktrees/

# Agent workflow sentinel files
.claude-workflow/

# Browser session data (persistent login cookies — NEVER commit)
browser-data/*
!browser-data/.gitkeep

# Reference workflows (local only — not part of the distributable system)
references/

# Git operation lock files
.git/workflow.lock

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.idea/
.vscode/

# Dependencies (project-specific — uncomment as needed)
# node_modules/
# __pycache__/
# *.pyc
# target/
# vendor/

# Build output (project-specific — uncomment as needed)
# dist/
# build/
# out/
# .next/

# Test artifacts
e2e-screenshots/
e2e-test-report.md
coverage/
.coverage
htmlcov/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
